@article{sormendi_hif2_2021,
	title = {{HIF2α} is a direct regulator of neutrophil motility},
	volume = {137},
	copyright = {All rights reserved},
	issn = {0006-4971},
	url = {https://doi.org/10.1182/blood.2020007505},
	doi = {10.1182/blood.2020007505},
	abstract = {Orchestrated recruitment of neutrophils to inflamed tissue is essential during the initiation of inflammation. Inflamed areas are usually hypoxic, and adaptation to reduced oxygen pressure is typically mediated by hypoxia pathway proteins. However, it remains unclear how these factors influence the migration of neutrophils to and at the site of inflammation during their transmigration through the blood-endothelial cell barrier, as well as their motility in the interstitial space. Here, we reveal that activation of hypoxia-inducible factor 2 (HIF2α) as a result of a deficiency in HIF prolyl hydroxylase domain protein 2 (PHD2) boosts neutrophil migration specifically through highly confined microenvironments. In vivo, the increased migratory capacity of PHD2-deficient neutrophils resulted in massive tissue accumulation in models of acute local inflammation. Using systematic RNA sequencing analyses and mechanistic approaches, we identified RhoA, a cytoskeleton organizer, as the central downstream factor that mediates HIF2α-dependent neutrophil motility. Thus, we propose that the novel PHD2-HIF2α-RhoA axis is vital to the initial stages of inflammation because it promotes neutrophil movement through highly confined tissue landscapes.},
	number = {24},
	urldate = {2023-11-01},
	journal = {Blood},
	author = {Sormendi, Sundary and Deygas, Mathieu and Sinha, Anupam and Bernard, Mathilde and Krüger, Anja and Kourtzelis, Ioannis and Le Lay, Gregoire and Sáez, Pablo J. and Gerlach, Michael and Franke, Kristin and Meneses, Ana and Kräter, Martin and Palladini, Alessandra and Guck, Jochen and Coskun, Ünal and Chavakis, Triantafyllos and Vargas, Pablo and Wielockx, Ben},
	month = jun,
	year = {2021},
	pages = {3416--3427},
	file = {Full Text PDF:/home/gregoire/Zotero/storage/JMK4YET6/Sormendi et al. - 2021 - HIF2α is a direct regulator of neutrophil motility.pdf:application/pdf;Snapshot:/home/gregoire/Zotero/storage/BFFB4Q8U/HIF2-is-a-direct-regulator-of-neutrophil-motility.html:text/html},
}


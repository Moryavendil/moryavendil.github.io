@article{bishop_lift_1997,
 abstract = {A circular cylinder was placed in a flowing fluid with its axis across the stream. The fluctuating lift and drag forces, and the steady drag force were measured. The results for the stationary cylinder were given in a previous paper (Bishop & Hassan 1964). Here, the results are described and summarized for a cylinder that is made to oscillate transversely in a direction perpendicular to the stream.},
 author = {Bishop, Richard Evelyn Donohue and Hassan, A. Y. and Saunders, O. A.},
 doi = {10.1098/rspa.1964.0005},
 file = {Full Text PDF:/home/gregoire/Zotero/storage/QYYM2SSQ/Bishop et al. - 1997 - The lift and drag forces on a circular cylinder os.pdf:application/pdf},
 journal = {Proceedings of the Royal Society of London. Series A. Mathematical and Physical Sciences},
 month = {January},
 note = {Publisher: Royal Society},
 number = {1368},
 pages = {51--75},
 title = {The lift and drag forces on a circular cylinder oscillating in a flowing fluid},
 url = {https://royalsocietypublishing.org/doi/10.1098/rspa.1964.0005},
 urldate = {2023-06-06},
 volume = {277},
 year = {1997}
}

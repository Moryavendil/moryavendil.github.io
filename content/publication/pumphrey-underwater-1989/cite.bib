@article{pumphrey_underwater_1989,
 abstract = {An experimental study of the underwater sound produced by water drop impacts on the surface is described. It is found that sound may be produced in two ways: first when the drop strikes the surface and, second, when a bubble is created in the water. The first process occurs for every drop; the second occurs for some impacts but not others. A range of conditions is described in which a bubble is produced for every drop impact, and it is shown that these conditions are likely to be met by a significant fraction of the raindrops in a typical shower. Underwater sound produced by artificial as well as real rain is reported. A comparison between artificial and real rain noise power spectra shows some deviations due to different drop‐size distributions. Addition of surface tension reducing liquids to the water in the test tank caused a disappearance of the characteristic spectral peaks in the frequency range 14–16 kHz. These peaks have been observed by several scientists during measurements of real rain. Our findings provide evidence for the theory that the 14‐ to 16‐kHz spectral peak is caused by the ringing of bubbles entrained in the water by the drop impact process.},
 author = {Pumphrey, Hugh C. and Crum, L. A. and Bjo/rno/, L.},
 doi = {10.1121/1.397353},
 file = {Full Text PDF:/home/gregoire/Zotero/storage/FGEJGMPP/Pumphrey et al. - 1989 - Underwater sound produced by individual drop impac.pdf:application/pdf;Snapshot:/home/gregoire/Zotero/storage/XMCXU5LD/Underwater-sound-produced-by-individual-drop.html:text/html},
 issn = {0001-4966},
 journal = {The Journal of the Acoustical Society of America},
 month = {April},
 number = {4},
 pages = {1518--1526},
 title = {Underwater sound produced by individual drop impacts and rainfall},
 url = {https://doi.org/10.1121/1.397353},
 urldate = {2023-04-26},
 volume = {85},
 year = {1989}
}

@misc{richter_studying_2023,
 abstract = {In this work we present an interferometry technique based on either two or three laser induced wavelengths to capture the transient contour of liquids close to the advancing three-phase contact line. A detailed insight into diﬀerent data analysis procedures is given, which can be used to evaluate data in cases where the experimental data quality contains diﬀerent types of errors or noise. Using the phase information contained in our experimental data, the technique allows an unambiguous determination of a local ﬁlm thickness for optical path diﬀerences up to ∆s ≈ 3.19 µm without the need of a known reference height for the given set of wavelengths. Small ﬁlm thicknesses down to values of about 0.1 µm are successfully analyzed with the presented methodology. The measurement technique is applied to study the spreading of a small droplet of a perfectly wetting ﬂuid on a smooth sapphire surface. The whole three dimensional droplet shape as well as its shape near the moving three phase contact line are investigated for diﬀerent capillary numbers revealing an extended mesoscopic droplet shape that is not well captured by classical theories.},
 author = {Richter, Timo and Fricke, Mathis and Hussong, Jeanette},
 file = {Richter et al. - 2023 - Studying Macro- and Mesoscopic Wetting Dynamics of.pdf:/home/gregoire/Zotero/storage/4GMJZAEU/Richter et al. - 2023 - Studying Macro- and Mesoscopic Wetting Dynamics of.pdf:application/pdf},
 keywords = {Physics - Fluid Dynamics},
 language = {en},
 month = {June},
 note = {arXiv:2306.13537 [physics]},
 publisher = {arXiv},
 title = {Studying Macro- and Mesoscopic Wetting Dynamics of a Spreading Oil Droplet Using Multiple Colour Interferometry},
 url = {http://arxiv.org/abs/2306.13537},
 urldate = {2023-06-26},
 year = {2023}
}

@article{donnelly_experiments_1966,
 abstract = {The stability of a vertical jet of water has been examined by imposing audio frequency disturbances. Flash photographs allow a direct measurement of the growth rate of the disturbances and the complete dispersion curve has been investigated. The effects of viscosity on the stability have been examined with glycerine-water solutions and have been found to be in good agreement with Chandrasekhar’s calculations.},
 annote = {A loudpeaker is attached to the structure, making it vibrate. 

A lneedle pin is glued to the loudpeaker and penetrates in the flow when large perturbations are wanted.  },
 author = {Donnelly, Russell James and Glaberson, W. and Chandrasekhar, Subrahmanyan},
 doi = {10.1098/rspa.1966.0069},
 file = {Full Text PDF:/home/gregoire/Zotero/storage/IQ6DVG8T/Donnelly et al. - 1997 - Experiments on the capillary instability of a liqu.pdf:application/pdf},
 journal = {Proceedings of the Royal Society of London. Series A. Mathematical and Physical Sciences},
 month = {January},
 note = {Publisher: Royal Society},
 number = {1423},
 pages = {547--556},
 title = {Experiments on the capillary instability of a liquid jet},
 url = {https://royalsocietypublishing.org/doi/10.1098/rspa.1966.0069},
 urldate = {2023-04-28},

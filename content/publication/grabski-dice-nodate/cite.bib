@article{grabski_dice_nodate,
 abstract = {In the paper some aspects of die throw dynamics are presented. Free fall of die as well as their collisions with table are analysed. Two models of collision are compared: first based on Newton's hypothesis and the second on Poisson's hypothesis. It is shown that from the point of view of dynamical systems dynamics of die is predictable.},
 author = {Grabski, Juliusz and Strzałko, Jarosław and Kapitaniak, Tomasz},
 file = {Grabski et al. - Dice Throw Dynamics Including Bouncing.pdf:/home/gregoire/Zotero/storage/3WKDQGUU/Grabski et al. - Dice Throw Dynamics Including Bouncing.pdf:application/pdf},
 language = {en},
 title = {Dice Throw Dynamics Including Bouncing}
}

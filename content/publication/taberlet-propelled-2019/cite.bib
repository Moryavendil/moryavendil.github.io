@article{taberlet_propelled_2019,
 abstract = {The shape of closed strings and chains propelled at a constant velocity and launched at an angle relative to gravity is studied experimentally, theoretically, and numerically. At low velocity, strings adopt a shape close to the well-known catenary, while at high velocity, they can rise to a nearly horizontal profile. We show that the latter regime can be counterintuitively attributed to aerodynamic effects, although the ambient air exerts no lift on a string moving longitudinally along its profile. A theoretical approach along with numerical simulations confirms these observations and allows one to predict the shape of any closed string or chain. Moreover, depending of the regime, waves rising from any local perturbation along the string may travel either upstream or downstream and seem to die out at the turning point. We show that these observations can be explained by the tension profile along the string, which strongly depends on the aerodynamic effects relative to the weight, and our theoretical analysis allows us to predict the position of the wave front.},
 author = {Taberlet, Nicolas and Ferrand, Jérémy and Plihon, Nicolas},
 doi = {10.1103/PhysRevLett.123.144501},
 file = {APS Snapshot:/home/gregoire/Zotero/storage/FFEGJNHF/PhysRevLett.123.html:text/html;Full Text PDF:/home/gregoire/Zotero/storage/RTQCJ8D9/Taberlet et al. - 2019 - Propelled Strings Rising from Friction.pdf:application/pdf},
 journal = {Physical Review Letters},
 month = {October},
 note = {Publisher: American Physical Society},
 number = {14},
 pages = {144501},
 shorttitle = {Propelled Strings},
 title = {Propelled Strings: Rising from Friction},
 url = {https://link.aps.org/doi/10.1103/PhysRevLett.123.144501},
 urldate = {2023-07-12},
 volume = {123},
 year = {2019}
}

@article{park_two-phase_1984,
 abstract = {A theory describing two-phase displacement in the gap between closely spaced planes is developed. The main assumptions of the theory are that the displaced fluid wets the walls, and that the capillary number Ca and the ratio of gap width to transverse characteristic length ε are both small. Relatively mild restrictions apply to the ratio M of viscosities of displacing to displaced fluids; in particular the theory holds for M = o(Ca−1/3). We formulate the theory as a double asymptotic expansion in the small parameters ε and Ca1/3. The expansion in ε is uniform while that in Ca1/3 is not, necessitating the use of matched asymptotic expansions. The previous work of Bretherton (1961) is clarified and extended, and both the form and the constants in the effective boundary condition of Chouke, van Meurs & van der Poel (1959) and of Saffman & Taylor (1958) are determined.},
 author = {Park, C.-W. and Homsy, G. M.},
 doi = {10.1017/S0022112084000367},
 file = {Full Text PDF:/home/gregoire/Zotero/storage/KCN96YCZ/Park and Homsy - 1984 - Two-phase displacement in Hele Shaw cells theory.pdf:application/pdf},
 issn = {1469-7645, 0022-1120},
 journal = {Journal of Fluid Mechanics},
 language = {en},
 month = {February},
 note = {Publisher: Cambridge University Press},
 pages = {291--308},
 shorttitle = {Two-phase displacement in Hele Shaw cells},
 title = {Two-phase displacement in Hele Shaw cells: theory},
 url = {https://www.cambridge.org/core/journals/journal-of-fluid-mechanics/article/twophase-displacement-in-hele-shaw-cells-theory/BBC5E9BF28134AC015627BD147CE7543},
 urldate = {2023-06-13},
 volume = {139},
 year = {1984}
}
